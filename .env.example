# Sofer SaaS Environment Configuration

# Server Port (Railway sets this automatically)
PORT=3001

# Node Environment
NODE_ENV=development

# API Keys (optional, only if using Claude)
ANTHROPIC_API_KEY=

# Ollama settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Session warmup (in milliseconds) - prevents immediate connections
# Set to 0 to disable (bypass session warmup)
SESSION_WARMUP_MS=300000

# For production
VITE_API_BASE=http://localhost:3001/api
